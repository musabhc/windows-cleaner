<Window x:Class="TemizPC.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:TemizPC.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1380"
        Height="940"
        MinWidth="1180"
        MinHeight="820"
        Background="{StaticResource WindowBackgroundBrush}"
        Icon="{StaticResource AppIconImage}"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        StateChanged="Window_OnStateChanged"
        UseLayoutRounding="True"
        WindowStyle="None">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="24"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CleanupTaskItemViewModel}">
            <Border Margin="0,0,0,16"
                    Padding="18"
                    Background="{Binding BackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1.4"
                    CornerRadius="22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              Margin="0,3,16,0"
                              VerticalAlignment="Top"
                              IsChecked="{Binding IsSelected}" />

                    <StackPanel Grid.Column="1">
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding Title}"
                                       FontFamily="Segoe UI Variable Display Semib"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <Border Margin="12,0,8,0"
                                    Padding="10,4"
                                    Background="{Binding AccentBrush}"
                                    CornerRadius="12">
                                <TextBlock Text="{Binding RiskLabel}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#08111D" />
                            </Border>

                            <Border Padding="10,4"
                                    Background="{StaticResource ChipBrush}"
                                    CornerRadius="12">
                                <TextBlock Text="{Binding PresetLabel}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="{Binding Description}"
                                   Style="{StaticResource BodyTextStyle}" />

                        <Border Margin="0,12,0,0"
                                Padding="12"
                                Background="#26171E"
                                CornerRadius="16"
                                Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding Warning}"
                                       FontSize="13"
                                       Foreground="#FFB8C5"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="WindowFrame"
            Margin="14"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="{StaticResource WindowFrameBorderBrush}"
            BorderThickness="1"
            CornerRadius="24"
            SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="14" />
                <Setter Property="CornerRadius" Value="24" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="CornerRadius" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Background="{StaticResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="18,14,14,12"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="30"
                                    Height="30"
                                    Background="#10243C"
                                    BorderBrush="#214169"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Image Width="18"
                                       Height="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Source="{StaticResource AppIconImage}"
                                       Stretch="Uniform" />
                            </Border>

                            <TextBlock Margin="12,0,12,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding WindowTitle}"
                                       FontFamily="Segoe UI Variable Display Semib"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <Border Padding="10,5"
                                    Background="#0E2035"
                                    CornerRadius="12">
                                <TextBlock Text="{Binding VersionBadgeText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#C7EEFF" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Margin="0,0,8,0"
                                Click="MinimizeButton_OnClick"
                                Content="_"
                                Style="{StaticResource TitleBarButtonStyle}" />
                        <Button x:Name="MaximizeRestoreButton"
                                Margin="0,0,8,0"
                                Click="MaximizeRestoreButton_OnClick"
                                Content="□"
                                Style="{StaticResource TitleBarButtonStyle}" />
                        <Button Click="CloseButton_OnClick"
                                Content="×"
                                Style="{StaticResource TitleBarCloseButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="24,20,24,18"
                    Padding="28"
                    Background="{StaticResource HeroBackgroundBrush}"
                    BorderBrush="#2B4A72"
                    BorderThickness="1.2"
                    CornerRadius="30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="82" Height="82" Margin="0,0,22,0">
                        <Grid Width="64" Height="64">
                            <Border Background="#0EA5E9" CornerRadius="18" />
                            <Border Margin="7,14,7,7" Background="#08111D" CornerRadius="11" />
                            <Border Margin="9,9,9,43" Background="#8BE8FF" CornerRadius="6" />
                            <Path Data="M45,10 L48,18 56,21 48,24 45,32 42,24 34,21 42,18 Z" Fill="#34D399" />
                            <Path Data="M22,26 L25,33 32,36 25,39 22,46 19,39 12,36 19,33 Z" Fill="#B6F4FF" />
                        </Grid>
                    </Viewbox>

                    <StackPanel Grid.Column="1" Margin="0,0,24,0">
                        <TextBlock Text="{Binding HeroTitle}" Style="{StaticResource TitleTextStyle}" />
                        <TextBlock Margin="0,10,0,18"
                                   Text="{Binding HeroSubtitle}"
                                   FontSize="15"
                                   Foreground="#D4E4F6"
                                   Style="{StaticResource BodyTextStyle}" />

                        <WrapPanel>
                            <Border Margin="0,0,10,10"
                                    Padding="12,6"
                                    Background="#15324A"
                                    CornerRadius="14">
                                <TextBlock Text="{Binding VersionBadgeText}"
                                           FontWeight="SemiBold"
                                           Foreground="#C7EEFF" />
                            </Border>

                            <Border Margin="0,0,10,10"
                                    Padding="12,6"
                                    Background="#18342E"
                                    CornerRadius="14">
                                <TextBlock Text="{Binding AdminBadgeText}"
                                           FontWeight="SemiBold"
                                           Foreground="#C2FAEE" />
                            </Border>

                            <Border Margin="0,0,10,10"
                                    Padding="12,6"
                                    Background="#1A2940"
                                    CornerRadius="14">
                                <TextBlock Text="{Binding UpdateStatusMessage}"
                                           FontWeight="SemiBold"
                                           Foreground="#D6E5F9" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Margin="0,0,8,10"
                                    Command="{Binding UseTurkishCommand}"
                                    Content="{Binding TurkishButtonText}"
                                    Style="{StaticResource GhostButtonStyle}" />
                            <Button Command="{Binding UseEnglishCommand}"
                                    Content="{Binding EnglishButtonText}"
                                    Style="{StaticResource GhostButtonStyle}" />
                        </StackPanel>

                        <Button Margin="0,0,0,10"
                                Command="{Binding CheckForUpdatesCommand}"
                                Content="{Binding CheckUpdatesButtonText}"
                                Style="{StaticResource SecondaryButtonStyle}" />

                        <Button Command="{Binding InstallUpdateCommand}"
                                Content="{Binding InstallUpdateButtonText}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2"
                          Margin="24,0,24,18"
                          Background="Transparent"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="1.25*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,22,0">
                        <UniformGrid Margin="0,0,0,24" Columns="3">
                            <Border Margin="0,0,14,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding RecommendedPresetTitle}"
                                               FontSize="19"
                                               Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,16"
                                               Text="{Binding RecommendedPresetDescription}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button Command="{Binding ApplyRecommendedPresetCommand}"
                                            Content="{Binding RecommendedPresetTitle}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,14,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding AdvancedPresetTitle}"
                                               FontSize="19"
                                               Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,16"
                                               Text="{Binding AdvancedPresetDescription}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button Command="{Binding ApplyAdvancedPresetCommand}"
                                            Content="{Binding AdvancedPresetTitle}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding OpenLogsButtonText}"
                                               FontSize="19"
                                               Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,16"
                                               Text="{Binding SummaryUntouchedText}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button Command="{Binding OpenLogsCommand}"
                                            Content="{Binding OpenLogsButtonText}"
                                            Style="{StaticResource GhostButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Margin="0,0,0,16"
                                   Text="{Binding SelectionTitle}"
                                   Style="{StaticResource SectionTitleTextStyle}" />

                        <Border Margin="0,0,0,24" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding RecommendedSectionTitle}"
                                           FontSize="19"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,18"
                                           Text="{Binding RecommendedPresetDescription}"
                                           Style="{StaticResource BodyTextStyle}" />
                                <ItemsControl ItemsSource="{Binding RecommendedTasks}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding AdvancedSectionTitle}"
                                           FontSize="19"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,18"
                                           Text="{Binding AdvancedPresetDescription}"
                                           Style="{StaticResource BodyTextStyle}" />
                                <ItemsControl ItemsSource="{Binding AdvancedTasks}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Margin="0,0,0,22" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding SummaryTitle}"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Margin="0,12,0,6"
                                           Text="{Binding SummarySelectedCountText}"
                                           FontFamily="Segoe UI Variable Display Semib"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding SummaryRiskText}" Style="{StaticResource BodyTextStyle}" />
                                <TextBlock Margin="0,10,0,18"
                                           Text="{Binding SummaryGuideText}"
                                           Style="{StaticResource BodyTextStyle}" />

                                <ItemsControl Margin="0,0,0,18" ItemsSource="{Binding SelectedTaskNames}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="12,8"
                                                    Background="{StaticResource ChipBrush}"
                                                    CornerRadius="14">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Margin="0,0,0,16"
                                           Text="{Binding SummaryUntouchedText}"
                                           Style="{StaticResource BodyTextStyle}" />

                                <Button Margin="0,0,0,10"
                                        Command="{Binding RunCleanupCommand}"
                                        Content="{Binding RunButtonText}"
                                        Style="{StaticResource PrimaryButtonStyle}" />

                                <Button Command="{Binding OpenLogsCommand}"
                                        Content="{Binding OpenLogsButtonText}"
                                        Style="{StaticResource GhostButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,22" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding ResultHeadline}"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Margin="0,12,0,12"
                                           Text="{Binding ResultSummary}"
                                           FontSize="15"
                                           Style="{StaticResource BodyTextStyle}" />
                                <TextBlock Text="{Binding ResultErrorSummary}"
                                           Foreground="#FFCCDA"
                                           Style="{StaticResource BodyTextStyle}" />

                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding LastRunTaskLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="12,10"
                                                    Background="#111B2D"
                                                    CornerRadius="14">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding ProgressText}"
                                           FontSize="19"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <ProgressBar Margin="0,14,0,0"
                                             Maximum="1"
                                             Value="{Binding ProgressValue}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Margin="24,0,24,20"
                    Padding="14,12"
                    Background="#0E1728"
                    BorderBrush="#1D2B44"
                    BorderThickness="1"
                    CornerRadius="18">
                <TextBlock Text="{Binding UpdateStatusMessage}"
                           Foreground="{StaticResource TextMutedBrush}" />
            </Border>
        </Grid>
    </Border>
</Window>
