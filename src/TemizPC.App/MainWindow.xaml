<Window x:Class="TemizPC.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TemizPC.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1380"
        Height="940"
        MinWidth="1180"
        MinHeight="820"
        Icon="{StaticResource AppIconImage}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CleanupTaskItemViewModel}">
            <Border Margin="0,0,0,16"
                    Padding="18"
                    CornerRadius="22"
                    BorderThickness="1.4"
                    Background="{Binding BackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              Margin="0,3,16,0"
                              VerticalAlignment="Top"
                              IsChecked="{Binding IsSelected}" />

                    <StackPanel Grid.Column="1">
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding Title}"
                                       FontFamily="Segoe UI Variable Display Semib"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <Border Margin="12,0,8,0"
                                    Padding="10,4"
                                    CornerRadius="12"
                                    Background="{Binding AccentBrush}">
                                <TextBlock Text="{Binding RiskLabel}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#08111D" />
                            </Border>

                            <Border Padding="10,4"
                                    CornerRadius="12"
                                    Background="{StaticResource ChipBrush}">
                                <TextBlock Text="{Binding PresetLabel}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="{Binding Description}"
                                   Style="{StaticResource BodyTextStyle}" />

                        <Border Margin="0,12,0,0"
                                Padding="12"
                                CornerRadius="16"
                                Background="#26171E"
                                Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding Warning}"
                                       Foreground="#FFB8C5"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="28,24,28,20"
                Padding="28"
                CornerRadius="30"
                Background="{StaticResource HeroBackgroundBrush}"
                BorderBrush="#2B4A72"
                BorderThickness="1.2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Viewbox Width="82" Height="82" Margin="0,0,22,0">
                    <Grid Width="64" Height="64">
                        <Border CornerRadius="18" Background="#0EA5E9" />
                        <Border Margin="7,14,7,7" CornerRadius="11" Background="#08111D" />
                        <Border Margin="9,9,9,43" CornerRadius="6" Background="#8BE8FF" />
                        <Path Fill="#34D399" Data="M45,10 L48,18 56,21 48,24 45,32 42,24 34,21 42,18 Z" />
                        <Path Fill="#B6F4FF" Data="M22,26 L25,33 32,36 25,39 22,46 19,39 12,36 19,33 Z" />
                    </Grid>
                </Viewbox>

                <StackPanel Grid.Column="1" Margin="0,0,24,0">
                    <TextBlock Text="{Binding HeroTitle}" Style="{StaticResource TitleTextStyle}" />
                    <TextBlock Margin="0,10,0,18"
                               Text="{Binding HeroSubtitle}"
                               Style="{StaticResource BodyTextStyle}"
                               FontSize="15"
                               Foreground="#D4E4F6" />

                    <WrapPanel>
                        <Border Margin="0,0,10,10"
                                Padding="12,6"
                                CornerRadius="14"
                                Background="#15324A">
                            <TextBlock Text="{Binding VersionBadgeText}"
                                       FontWeight="SemiBold"
                                       Foreground="#C7EEFF" />
                        </Border>

                        <Border Margin="0,0,10,10"
                                Padding="12,6"
                                CornerRadius="14"
                                Background="#18342E">
                            <TextBlock Text="{Binding AdminBadgeText}"
                                       FontWeight="SemiBold"
                                       Foreground="#C2FAEE" />
                        </Border>

                        <Border Margin="0,0,10,10"
                                Padding="12,6"
                                CornerRadius="14"
                                Background="#1A2940">
                            <TextBlock Text="{Binding UpdateStatusMessage}"
                                       FontWeight="SemiBold"
                                       Foreground="#D6E5F9" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Margin="0,0,8,10"
                                Content="{Binding TurkishButtonText}"
                                Command="{Binding UseTurkishCommand}"
                                Style="{StaticResource GhostButtonStyle}" />
                        <Button Content="{Binding EnglishButtonText}"
                                Command="{Binding UseEnglishCommand}"
                                Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>

                    <Button Margin="0,0,0,10"
                            Content="{Binding CheckUpdatesButtonText}"
                            Command="{Binding CheckForUpdatesCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />

                    <Button Content="{Binding InstallUpdateButtonText}"
                            Command="{Binding InstallUpdateCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="28,0,28,20" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,22,0">
                    <UniformGrid Columns="3" Margin="0,0,0,24">
                        <Border Margin="0,0,14,0" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding RecommendedPresetTitle}"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="19" />
                                <TextBlock Margin="0,10,0,16"
                                           Text="{Binding RecommendedPresetDescription}"
                                           Style="{StaticResource BodyTextStyle}" />
                                <Button Content="{Binding RecommendedPresetTitle}"
                                        Command="{Binding ApplyRecommendedPresetCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,14,0" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding AdvancedPresetTitle}"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="19" />
                                <TextBlock Margin="0,10,0,16"
                                           Text="{Binding AdvancedPresetDescription}"
                                           Style="{StaticResource BodyTextStyle}" />
                                <Button Content="{Binding AdvancedPresetTitle}"
                                        Command="{Binding ApplyAdvancedPresetCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding OpenLogsButtonText}"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="19" />
                                <TextBlock Margin="0,10,0,16"
                                           Text="{Binding SummaryUntouchedText}"
                                           Style="{StaticResource BodyTextStyle}" />
                                <Button Content="{Binding OpenLogsButtonText}"
                                        Command="{Binding OpenLogsCommand}"
                                        Style="{StaticResource GhostButtonStyle}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Margin="0,0,0,16"
                               Text="{Binding SelectionTitle}"
                               Style="{StaticResource SectionTitleTextStyle}" />

                    <Border Margin="0,0,0,24" Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding RecommendedSectionTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       FontSize="19" />
                            <TextBlock Margin="0,8,0,18"
                                       Text="{Binding RecommendedPresetDescription}"
                                       Style="{StaticResource BodyTextStyle}" />
                            <ItemsControl ItemsSource="{Binding RecommendedTasks}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding AdvancedSectionTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       FontSize="19" />
                            <TextBlock Margin="0,8,0,18"
                                       Text="{Binding AdvancedPresetDescription}"
                                       Style="{StaticResource BodyTextStyle}" />
                            <ItemsControl ItemsSource="{Binding AdvancedTasks}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Margin="0,0,0,22" Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding SummaryTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,12,0,6"
                                       Text="{Binding SummarySelectedCountText}"
                                       FontFamily="Segoe UI Variable Display Semib"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding SummaryRiskText}" Style="{StaticResource BodyTextStyle}" />
                            <TextBlock Margin="0,10,0,18"
                                       Text="{Binding SummaryGuideText}"
                                       Style="{StaticResource BodyTextStyle}" />

                            <ItemsControl Margin="0,0,0,18" ItemsSource="{Binding SelectedTaskNames}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12,8"
                                                CornerRadius="14"
                                                Background="{StaticResource ChipBrush}">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Margin="0,0,0,16"
                                       Text="{Binding SummaryUntouchedText}"
                                       Style="{StaticResource BodyTextStyle}" />

                            <Button Margin="0,0,0,10"
                                    Content="{Binding RunButtonText}"
                                    Command="{Binding RunCleanupCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />

                            <Button Content="{Binding OpenLogsButtonText}"
                                    Command="{Binding OpenLogsCommand}"
                                    Style="{StaticResource GhostButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,22" Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding ResultHeadline}"
                                       Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,12,0,12"
                                       Text="{Binding ResultSummary}"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontSize="15" />
                            <TextBlock Text="{Binding ResultErrorSummary}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Foreground="#FFCCDA" />

                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding LastRunTaskLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12,10"
                                                CornerRadius="14"
                                                Background="#111B2D">
                                            <TextBlock Text="{Binding}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding ProgressText}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       FontSize="19" />
                            <ProgressBar Margin="0,14,0,0"
                                         Value="{Binding ProgressValue}"
                                         Maximum="1" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Margin="28,0,28,24"
                Padding="14,12"
                CornerRadius="18"
                Background="#0E1728"
                BorderBrush="#1D2B44"
                BorderThickness="1">
            <TextBlock Text="{Binding UpdateStatusMessage}"
                       Foreground="{StaticResource TextMutedBrush}" />
        </Border>
    </Grid>
</Window>
