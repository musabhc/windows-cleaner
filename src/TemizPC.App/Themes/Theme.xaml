<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#09111F" Offset="0" />
        <GradientStop Color="#0D1830" Offset="0.45" />
        <GradientStop Color="#0B1526" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#132948" Offset="0" />
        <GradientStop Color="#163964" Offset="0.55" />
        <GradientStop Color="#11233C" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PanelBrush" Color="#101B2D" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#21304A" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F7FB" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FB0C6" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#72839C" />
    <SolidColorBrush x:Key="AccentBrush" Color="#38BDF8" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#15324A" />
    <SolidColorBrush x:Key="PositiveBrush" Color="#2DD4BF" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FB7185" />
    <SolidColorBrush x:Key="ChipBrush" Color="#18273E" />

    <DrawingImage x:Key="AppIconImage">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#0EA5E9" Geometry="F1 M6,4 H58 A6,6 0 0 1 64,10 V54 A6,6 0 0 1 58,60 H6 A6,6 0 0 1 0,54 V10 A6,6 0 0 1 6,4 Z" />
                <GeometryDrawing Brush="#08111D" Geometry="F1 M8,18 H56 V48 H8 Z" />
                <GeometryDrawing Brush="#8BE8FF" Geometry="F1 M10,10 H54 V16 H10 Z" />
                <GeometryDrawing Brush="#34D399" Geometry="F1 M44,12 L47,20 55,23 47,26 44,34 41,26 33,23 41,20 Z" />
                <GeometryDrawing Brush="#B6F4FF" Geometry="F1 M21,25 L24,32 31,35 24,38 21,45 18,38 11,35 18,32 Z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="WindowStartupLocation" Value="CenterScreen" />
    </Style>

    <Style x:Key="PanelCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="26" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display Semib" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display Semib" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="#F9FDFF" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="#182842" />
        <Setter Property="BorderBrush" Value="#182842" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="#0F1726" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="#132036" />
    </Style>
</ResourceDictionary>
